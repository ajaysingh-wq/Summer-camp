1. What is the output?
void fun(int n){
    if(n==0) return;
    cout<<n<<" ";
    fun(n-1);
    cout<<n<<" ";
}

fun(3);

Answer:

3 2 1 1 2 3
2. How many times is fun() called?
int fun(int n){
    if(n<=1) return 1;
    return fun(n-1)+fun(n-2);
}

fun(5);

Answer: 15 calls

3. What is the output?
void fun(int n){
    if(n==0) return;
    fun(n-1);
    cout<<n<<" ";
}

fun(4);

Answer:

1 2 3 4
4. Find the value.
int fun(int n){
    if(n==1) return 1;
    return n + fun(n-1);
}

fun(5);

Answer: 15

5. Find the recurrence and complexity.
void fun(int n){
    if(n<=1) return;
    fun(n-1);
}

Answer:

T(n)=T(n−1)+1
Θ(n)
6. Solve:
T(n)=T(n−1)+n

Answer:

Θ(n²)
7. Solve:
T(n)=T(n/2)+1

Answer:

Θ(log n)
8. Solve:
T(n)=2T(n/2)+n

Answer:

Θ(n log n)
9. Solve:
T(n)=4T(n/2)+n

Answer:

Θ(n²)
